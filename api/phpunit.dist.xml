<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         failOnDeprecation="true"
         failOnNotice="true"
         failOnWarning="true">
    <php>
        <ini name="display_errors" value="1"/>
        <ini name="error_reporting" value="-1"/>
        <server name="APP_ENV" value="test" force="true"/>
        <server name="SHELL_VERBOSITY" value="-1"/>

        <env name="APP_SECRET" value="test-secret"/>
        <env name="DEFAULT_URI" value="http://localhost"/>

        <!-- Fallback (exécution hors docker/CI) : l'env réel prime s'il est défini.
             En environnement test, Doctrine suffixe le nom de base en `_test`. -->
        <env name="DATABASE_URL" value="postgresql://plume:plume@127.0.0.1:5432/plume?serverVersion=17&amp;charset=utf8"/>

        <!-- Clés JWT éphémères de test, générées par tests/bootstrap.php (var/jwt-test). -->
        <env name="JWT_SECRET_KEY" value="%kernel.project_dir%/var/jwt-test/private.pem"/>
        <env name="JWT_PUBLIC_KEY" value="%kernel.project_dir%/var/jwt-test/public.pem"/>
        <env name="JWT_PASSPHRASE" value="test-only-not-a-secret"/>
    </php>

    <testsuites>
        <testsuite name="unit">
            <directory>tests</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
