# Valeurs par défaut (dev). Surcharger dans .env.local (non versionné).
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_in_env_local
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Génération d'URL hors contexte HTTP (commandes CLI).
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Hôte "database" = service Docker Compose (cf. compose.yaml à la racine).
DATABASE_URL="postgresql://plume:plume@database:5432/plume?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default
###< symfony/messenger ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_env_local
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> drafting (M1.4 — rédaction assistée) ###
# Clé absente => générateur local déterministe (canned), coût zéro (dev/CI/E2E).
ANTHROPIC_API_KEY=
DRAFTING_MODEL=claude-sonnet-5
###< drafting ###

###> mailbox (M2 — passerelle email) ###
# Sans GOOGLE_CLIENT_ID : connecteur factice (dev/CI/E2E, aucun compte réel).
# En prod : identifiants OAuth Google + clé de chiffrement DÉDIÉE (ADR-0016) :
#   MAILBOX_ENCRYPTION_KEY=$(php -r "echo base64_encode(random_bytes(32));")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/gmail/callback
MAILBOX_ENCRYPTION_KEY=
###< mailbox ###
