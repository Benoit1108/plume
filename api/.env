# Valeurs par défaut (dev). Surcharger dans .env.local (non versionné).
APP_ENV=dev
APP_SECRET=change_me_in_env_local

DATABASE_URL="postgresql://plume:plume@database:5432/plume?serverVersion=17&charset=utf8"

MESSENGER_TRANSPORT_DSN=doctrine://default

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_env_local
###< lexik/jwt-authentication-bundle ###

CORS_ALLOW_ORIGIN='^https?://localhost:3000$'
